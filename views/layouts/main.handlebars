<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrefour - Vencimentos</title>
    <link rel="shortcut icon" href="/img/logo.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>


    <header>
        <figure>
            <img src="/img/logo.png" alt="Logotipo Carrefour">
        </figure>


        {{#if session.userid}}
        <nav>
            <div class="abas">
                <a href="/vencimentos/verVencimentos">Meus vencimentos</a>
                <a href="/vencimentos/novoVencimento">Novo vencimento</a>
                <a href="/vencimentos/buscaFornecedor">Filtro por fornecedor</a>
                <a href="/vencimentos/buscaProduto">Filtro por produto</a>
                <a href="/vencimentos/buscaData">Filtro por data</a>
            </div>
        </nav>
        <nav>
            <div class="abas2">
                <a href="/">Início</a>
                <a href="/logout">Logout</a>

            </div>
        </nav>
        {{else}}
        <nav>
            <a href="/abrirRegistro">Registre-se aqui</a>
            <a href="/abrirLogin">Login</a>

        </nav>


        {{/if}}


    </header>
    <div class="avisos">
        {{#if messages.m}}
        {{messages.m}}
        {{/if}}
    </div>
    <div class="container">
        {{{body}}}
    </div>
    <footer>
        <h2>Mapa do site:</h2>
        <div class="mapa">
            <ul>
                <li><a href="/abrirRegistro">Novo usuário</a></li>
                <li><a href="/abrirLogin">Login</a></li>
            </ul>


            <ul>
                <li><a href="/vencimentos/verVencimentos">Meus vencimentos</a></li>
                <li><a href="/vencimentos/novoVencimento">Novo vencimento</a></li>
                <li><a href="/vencimentos/buscaFornecedor">Filtro por fornecedor</a></li>
                <li><a href="/vencimentos/buscaProduto">Filtro por produto</a></li>
                <li><a href="/vencimentos/buscaData">Filtro por data</a></li>

            </ul>
        </div>
        <p>Criado por: Sandro da Paixão Coelho </p>
    </footer>


</body>

</html>